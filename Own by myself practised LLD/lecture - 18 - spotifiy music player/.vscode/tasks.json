{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile java",
            "type": "shell",
            "command": "javac",
            "args": ["-d", ".bin", "*.java"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "run java with file I/O",
            "type": "shell",
            "command": "powershell.exe",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "run.ps1"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "run java normal",
            "type": "shell",
            "command": "java",
            "args": ["-cp", ".bin", "Code"],
            "group": "test",
            "dependsOn": "compile java",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}